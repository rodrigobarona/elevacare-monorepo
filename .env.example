# ---------------------------------------------------------------------------
# Eleva.care v3 — .env.example
# Authoritative list of environment variables expected across the monorepo.
# Values come from Vercel Marketplace integrations (Neon, Upstash, Resend,
# Sentry, BetterStack) or are set manually in Vercel project env.
# Run `vercel env pull .env.local` per app to sync.
# ---------------------------------------------------------------------------

# ======== Platform / multi-zone (S0) ========
APP_URL=https://dev.eleva.care
API_URL=https://api.dev.eleva.care
DOCS_URL=https://dev.eleva.care/docs
APP_ASSET_PREFIX=
API_ASSET_PREFIX=
DOCS_ASSET_PREFIX=

# ======== Identity — WorkOS (S1) ========
# packages/auth consumes these; no other package may import @workos-inc/node.
WORKOS_API_KEY=sk_test_...
WORKOS_CLIENT_ID=client_...
WORKOS_COOKIE_PASSWORD=
WORKOS_REDIRECT_URI=https://dev.eleva.care/callback

# ======== Database — Neon (S1) ========
# Two Neon projects: main + audit. Marketplace auto-populates.
DATABASE_URL=postgres://...
DATABASE_URL_UNPOOLED=postgres://...
AUDIT_DATABASE_URL=postgres://...
AUDIT_DATABASE_URL_UNPOOLED=postgres://...

# ======== Encryption / Vault (S1) ========
# Keys live in WorkOS Vault; never put ENCRYPTION_KEY in env (CI rejects it).
WORKOS_VAULT_NAMESPACE=eleva-v3-main

# ======== Feature flags — Vercel Flags + Edge Config (S1) ========
EDGE_CONFIG=https://edge-config.vercel.com/...
FLAGS_SECRET=

# ======== Observability — Sentry + BetterStack (S1) ========
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
BETTERSTACK_HEARTBEAT_URL=
BETTERSTACK_LOGS_SOURCE_TOKEN=

# ======== Coordination — Upstash Redis + QStash (S3/S4) ========
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ======== Payments — Stripe Connect Express (S2/S4) ========
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=
STRIPE_API_VERSION=2023-08-16

# ======== Accounting — TOConline / Moloni (S2/S6) ========
TOCONLINE_CLIENT_ID=
TOCONLINE_CLIENT_SECRET=
TOCONLINE_OAUTH_REDIRECT=https://dev.eleva.care/expert/onboarding/invoicing/toconline/callback
MOLONI_CLIENT_ID=
MOLONI_CLIENT_SECRET=

# ======== Calendar — Google + Microsoft (S3) ========
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT=https://dev.eleva.care/calendar/google/callback
MS_OAUTH_CLIENT_ID=
MS_OAUTH_CLIENT_SECRET=
MS_OAUTH_REDIRECT=https://dev.eleva.care/calendar/microsoft/callback

# ======== Notifications — Resend + Twilio (S4) ========
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@dev.eleva.care
RESEND_WEBHOOK_SECRET=
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=

# ======== Durable workflows — Vercel Workflows DevKit (S4) ========
VERCEL_WORKFLOWS_TOKEN=

# ======== AI — Vercel AI Gateway (S5) ========
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=https://gateway.ai.vercel.app

# ======== Video + transcripts — Daily.co (S5) ========
DAILY_API_KEY=
DAILY_DOMAIN=eleva
DAILY_WEBHOOK_SECRET=

# ======== File storage — Vercel Blob (S2) ========
BLOB_READ_WRITE_TOKEN=

# ======== Analytics — GA4 (web) + PostHog (app) (S7) ========
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ======== Turbo remote cache (CI) ========
TURBO_TOKEN=
TURBO_TEAM=
TURBO_REMOTE_CACHE_SIGNATURE_KEY=
