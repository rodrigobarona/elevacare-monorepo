{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NODE_ENV",
    "VERCEL",
    "VERCEL_ENV",
    "VERCEL_URL",
    "APP_URL",
    "API_URL",
    "DOCS_URL",
    "APP_ASSET_PREFIX",
    "API_ASSET_PREFIX",
    "DOCS_ASSET_PREFIX",
    "WORKOS_API_KEY",
    "WORKOS_CLIENT_ID",
    "WORKOS_COOKIE_PASSWORD",
    "WORKOS_REDIRECT_URI",
    "WORKOS_VAULT_NAMESPACE",
    "DATABASE_URL",
    "DATABASE_URL_UNPOOLED",
    "AUDIT_DATABASE_URL",
    "AUDIT_DATABASE_URL_UNPOOLED",
    "SENTRY_DSN",
    "NEXT_PUBLIC_SENTRY_DSN",
    "SENTRY_ORG",
    "SENTRY_PROJECT",
    "SENTRY_AUTH_TOKEN",
    "BETTERSTACK_HEARTBEAT_URL",
    "BETTERSTACK_LOGS_SOURCE_TOKEN",
    "CRON_SECRET",
    "EDGE_CONFIG",
    "FLAGS_SECRET",
    "UPSTASH_REDIS_REST_URL",
    "UPSTASH_REDIS_REST_TOKEN",
    "QSTASH_TOKEN",
    "QSTASH_CURRENT_SIGNING_KEY",
    "QSTASH_NEXT_SIGNING_KEY",
    "WORKFLOWS_DRAIN_SECRET",
    "RESEND_API_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^typecheck"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "vitest.config.ts",
        "../../vitest.shared.ts"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
