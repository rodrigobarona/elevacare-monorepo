{
  "extends": "@eleva/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@eleva/ui/*": ["../../packages/ui/src/*"]
    },
    "plugins": [{ "name": "next" }]
  },
  "include": ["next-env.d.ts", "next.config.mjs", "src/**/*", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
